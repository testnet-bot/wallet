generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  address      String            @id
  balance      String
  healthScore  Int               @default(100)
  riskLevel    String            @default("LOW")
  lastSynced   DateTime          @default(now())
  
  // --- NEW 2026 INTEL FIELDS ---
  isDelegated  Boolean           @default(false)
  metadata     Json?             // Stores { indicators: string[], traceId: string }
  
  rules        AutomationRule[]
  sessionKeys  SessionKey[]
}

model AutomationRule {
  id            Int      @id @default(autoincrement())
  walletAddress String
  privateKey    String   
  chain         String
  type          String   
  active        Boolean  @default(true)
  targetBalance String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt 
  wallet        Wallet   @relation(fields: [walletAddress], references: [address])

  @@index([walletAddress, active])
}

model ApiKey {
  id           String           @id @default(cuid())
  key          String           @unique
  wallet       String           @unique
  plan         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  lastActive   DateTime         @default(now())
  usage        Int              @default(0)
  subscription ApiSubscription?
  analytics    ApiAnalytics[]

  @@index([wallet])
}

model Payment {
  id        String   @id @default(cuid())
  traceId   String?  @unique
  wallet    String
  txHash    String?  @unique
  amount    Float    
  rawAmount String?  
  chain     String
  status    String   @default("PENDING") 
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([wallet, status])
}

model RecoveryAttempt {
  id                String   @id @default(cuid())
  traceId           String?  @unique
  walletAddress     String
  tokenCount        Int
  estimatedTotalUsd String
  status            String   
  createdAt         DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([walletAddress])
}

model SystemLock {
  id        String   @id 
  isLocked  Boolean  @default(false)
  ownerId   String?  
  updatedAt DateTime @updatedAt
}

model ApiSubscription {
  id            String    @id @default(cuid())
  apiKeyId      String    @unique
  planType      String    @default("BASIC") 
  requestLimit  Int       @default(1000)
  currentUsage  Int       @default(0)
  startsAt      DateTime  @default(now())
  endsAt        DateTime  
  isActive      Boolean   @default(true)
  autoRenew     Boolean   @default(false)
  updatedAt     DateTime  @updatedAt
  apiKey        ApiKey    @relation(fields: [apiKeyId], references: [id])
}

model ThreatIntel {
  id          String   @id @default(cuid())
  pattern     String   @unique 
  threatType  String   
  riskLevel   Int      @default(90)
  detectedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  occurrences Int      @default(1)
  
  @@index([pattern])
}

model SessionKey {
  id            String   @id @default(cuid())
  walletAddress String
  publicKey     String
  encryptedKey  String   
  permissions   Json     
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  wallet        Wallet   @relation(fields: [walletAddress], references: [address])

  @@index([walletAddress, isActive])
}

model SimulationLog {
  id            String   @id @default(cuid())
  walletAddress String
  txHash        String?
  isSafe        Boolean
  riskScore     Int      
  diff          Json?    
  createdAt     DateTime @default(now())

  @@index([walletAddress])
}

model ForensicAudit {
  id                String   @id @default(cuid())
  walletAddress     String
  targetAddress     String   
  isSafe            Boolean
  riskScore         Int      
  verdict           String   
  simulationPayload Json     
  contractMetadata  Json     
  behaviorPatterns  Json     
  createdAt         DateTime @default(now())
  
  @@index([walletAddress, targetAddress])
}

model ApiAnalytics {
  id            String   @id @default(cuid())
  apiKeyId      String
  endpoint      String
  statusCode    Int
  responseTime  Int      
  riskDetected  Boolean  @default(false)
  gasSaved      String?  
  createdAt     DateTime @default(now())
  apiKey        ApiKey    @relation(fields: [apiKeyId], references: [id])

  @@index([apiKeyId, createdAt])
}
